# Caddyfile for Media Manager SPA
# Replace YOUR_DOMAIN with your actual domain

YOUR_DOMAIN {
    header {
        Referrer-Policy "same-origin"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
    }
    
    # === MEDIA MANAGER (port 8080) - Everything proxied, token required ===
    # API routes
    handle_path /api/* {
        reverse_proxy localhost:8080
    }
    
    # Stream routes
    handle_path /stream/* {
        reverse_proxy localhost:8080
    }
    
    # All other routes (static files, SPA) - go to FastAPI with token auth
    reverse_proxy localhost:8080
    
    # Automatic HTTPS (Caddy handles certificates)
    tls {
        # Use built-in ACME (Let's Encrypt) - no config needed
    }
}
