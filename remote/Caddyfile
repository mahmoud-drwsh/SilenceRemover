# Caddyfile for MP3 Manager SPA
# Replace YOUR_DOMAIN with your actual domain

YOUR_DOMAIN {
    # Static files served directly by Caddy (zero Flask CPU)
    handle_path /static/* {
        root * /var/lib/mp3-manager/static
        file_server
        header Cache-Control "public, max-age=86400"
    }
    
    # API endpoints go to Flask
    handle_path /api/* {
        reverse_proxy localhost:8080
    }
    
    # Audio streaming
    handle_path /stream/* {
        reverse_proxy localhost:8080
    }
    
    # Everything else (SPA routes) goes to Flask (serves index.html)
    reverse_proxy localhost:8080
    
    # Automatic HTTPS (Caddy handles certificates)
    tls {
        # Use built-in ACME (Let's Encrypt) - no config needed
    }
}
