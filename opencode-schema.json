{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "./opencode-schema.json",
  "title": "OpenCode Policy Configuration",
  "description": "Schema for defining command execution policies in pi-coding-agent via extension",
  "type": "object",
  "required": ["name", "version"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema file"
    },
    "name": {
      "type": "string",
      "description": "Policy name"
    },
    "version": {
      "type": "string",
      "description": "Policy version (semver)"
    },
    "description": {
      "type": "string",
      "description": "Human-readable policy description"
    },
    "commands": {
      "type": "object",
      "description": "Command policies by tool",
      "properties": {
        "bash": {
          "type": "object",
          "description": "Bash command policies",
          "patternProperties": {
            "^.*$": {
              "type": "string",
              "enum": ["allow", "ask", "deny"],
              "description": "Policy for this command: allow=auto-run, ask=prompt-user, deny=block"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}