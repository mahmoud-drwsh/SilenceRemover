{
  "$schema": "./opencode-schema.json",
  "name": "safe-commands-only",
  "version": "1.0.0",
  "description": "Read-only safe command policy with ask-before-run for others",
  "commands": {
    "bash": {
      "*": "ask",
      "ls": "allow",
      "cat": "allow",
      "less": "allow",
      "more": "allow",
      "pwd": "allow",
      "echo": "allow",
      "file": "allow",
      "stat": "allow",
      "find": "allow",
      "grep": "allow",
      "rg": "allow",
      "head": "allow",
      "tail": "allow",
      "wc": "allow",
      "sort": "allow",
      "uniq": "allow",
      "cut": "allow",
      "awk": "allow",
      "sed": "allow",
      "tr": "allow",
      "diff": "allow",
      "cmp": "allow",
      "strings": "allow",
      "realpath": "allow",
      "readlink": "allow",
      "basename": "allow",
      "dirname": "allow",
      "which": "allow",
      "whereis": "allow",
      "type": "allow",
      "uname": "allow",
      "hostname": "allow",
      "date": "allow",
      "whoami": "allow",
      "id": "allow",
      "groups": "allow",
      "uptime": "allow",
      "env": "allow",
      "printenv": "allow",
      "ps": "allow",
      "pgrep": "allow",
      "top": "allow",
      "htop": "allow",
      "df": "allow",
      "du": "allow",
      "mount": "allow",
      "git": "allow",
      "python": "allow",
      "python3": "allow",
      "node": "allow",
      "npm": "allow",
      "pip": "allow",
      "uv": "allow",
      "cargo": "allow",
      "rustc": "allow",
      "go": "allow",
      "java": "allow",
      "javac": "allow",
      "gcc": "allow",
      "g++": "allow",
      "clang": "allow",
      "make": "ask",
      "cmake": "ask",
      "mkdir": "ask",
      "touch": "ask"
    }
  }
}