{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "bash": {
      "*": "ask",
      "git *": "allow",
      "npm *": "allow",
      "rm *": "deny",
      "grep *": "allow",
      "ls *": "allow",
      "find *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "echo *": "allow",
      "which *": "allow",
      "env": "allow",
      "printenv *": "allow",
      "pwd": "allow",
      "date": "allow",
      "file *": "allow",
      "wc *": "allow",
      "stat *": "allow",
      "du *": "allow",
      "sort *": "allow",
      "uniq *": "allow",
      "cut *": "allow",
      "diff *": "allow",
      "uname *": "allow",
      "id": "allow",
      "ps *": "allow",
      "pgrep *": "allow",
      "python *": "allow",
      "uv *": "allow",
      "ffmpeg *": "allow",
      "ffprobe *": "allow"
    },
    "edit": "allow",
    "write": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "external_directory": "ask",
    "webfetch": "allow",
    "task": "ask",
    "skill": "ask",
    "doom_loop": "ask"
  }
}
