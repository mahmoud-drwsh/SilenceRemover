# Copy to .env and fill in values. Do not commit .env.

# Required for transcription and title generation (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Telegram text when Phase 3 final encoding starts and when it finishes successfully.
# Create a bot via @BotFather; chat id is numeric (user/group) or @channelusername for channels.
# TELEGRAM_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_CHAT_ID=-1001234567890
# Optional override for self-hosted Bot API (default: https://api.telegram.org)
# TELEGRAM_API_BASE=https://api.telegram.org

# Optional: title editor HTTP port (default 8765)
# TITLE_EDITOR_PORT=8765

# Models, silence params, trim targets, etc. are CLI flags and constants in
# src/core/config.py and src/core/constants.py — not environment variables.
