# Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env to git.

# =============================================================================
# REQUIRED
# =============================================================================

# OpenRouter API key for transcription and title generation
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# =============================================================================
# OPTIONAL: Telegram Notifications
# =============================================================================

# Telegram bot token from @BotFather (format: numbers:alphanumeric)
# TELEGRAM_BOT_TOKEN=7123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Telegram chat ID where notifications are sent
# Can be numeric user/group ID or @channelusername for channels
# TELEGRAM_CHAT_ID=-1001234567890

# Optional: Self-hosted Bot API server (defaults to https://api.telegram.org)
# TELEGRAM_API_BASE=https://api.telegram.org


# =============================================================================
# OPTIONAL: Media Manager Integration
# =============================================================================

# Media Manager URL for title sync and file upload
# Format: https://host/token/project/
# Enables the 5-phase workflow:
#   1. API fetch → local title.txt sync + re-encode trigger at pipeline start
#   2. Phase 3: Auto-upload audio snippet + AI title if not on server
#   3. Phase 5: Upload final video when audio marked "ready"
# MEDIA_MANAGER_URL=https://example.com/TOKEN/arabic-lessons/


# =============================================================================
# NOTES
# =============================================================================
# - All other configuration (models, silence thresholds, trim targets, etc.)
#   are CLI flags defined in src/core/cli.py or constants in src/core/constants.py
# - This file only contains secrets and service endpoints that must not be
#   hardcoded in source files
